# Sheaf Configuration
# Copy to .env and modify as needed: cp .env.example .env

# =============================================================================
# ENCRYPTION KEY — READ THIS
# =============================================================================
# Used for two things you cannot afford to lose:
#   1. XChaCha20-Poly1305 encryption of emails and TOTP secrets at rest.
#   2. Keys the blind-index (HMAC-SHA-256) used to look up users by email at
#      login. With no key, the email_hash column becomes meaningless.
#
# If not set, Sheaf will auto-generate a key on first startup and save it to
# data/encryption.key. YOU MUST BACK THIS UP. If you lose it, all encrypted
# data is unrecoverable AND nobody will be able to log in — the server
# literally cannot map an inbound email address back to a user row.
#
# Setting SHEAF_ENCRYPTION_KEY explicitly (not relying on the auto-generated
# file in the docker volume) is strongly recommended for any long-lived
# install.
#
# To generate your own: python -c "import secrets; print(secrets.token_hex(32))"
# SHEAF_ENCRYPTION_KEY=your-32-byte-hex-key-here

# =============================================================================
# Database
# =============================================================================
POSTGRES_PASSWORD=changeme-in-production
DATABASE_URL=postgresql+asyncpg://sheaf:${POSTGRES_PASSWORD}@db:5432/sheaf

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Auth
# =============================================================================
# Required. Signs access / refresh tokens and keys the HMAC applied to
# password-reset and email-verification tokens stored in the DB. Must be a
# strong random value and must stay stable for the lifetime of the install —
# rotating it invalidates every active session and every outstanding
# password-reset / email-verification link.
#
# Sheaf refuses to start in SHEAF_MODE=saas with the default value, and logs
# a loud warning in selfhosted mode. The default is for local dev only.
#
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=changeme-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
SESSION_EXPIRE_HOURS=24

# =============================================================================
# Mode: "selfhosted" or "saas"
# =============================================================================
# Self-hosted: all features enabled, no tier restrictions, no pruning
# SaaS: tier-based feature gates, front history pruning for free tier
SHEAF_MODE=selfhosted

# =============================================================================
# SaaS Settings (only used when SHEAF_MODE=saas)
# =============================================================================
FREE_TIER_FRONT_RETENTION_DAYS=30

# Revision-history retention caps per tier. 0 = unlimited.
# Covers both journal entries and member bios. Per-system overrides in the
# Safety panel can lower these but never raise above the tier max.
# JOURNAL_MAX_REVISIONS_FREE=10
# JOURNAL_MAX_REVISIONS_PLUS=100
# JOURNAL_MAX_REVISIONS_SELFHOSTED=0
# JOURNAL_MAX_REVISION_DAYS_FREE=30
# JOURNAL_MAX_REVISION_DAYS_PLUS=365
# JOURNAL_MAX_REVISION_DAYS_SELFHOSTED=0

# Per-target pinned-revision caps. Pinned revisions are exempt from the
# rolling retention sweep above, so this bounds extra storage from pins.
# Per-system override in the Safety panel can lower but not raise.
# PINNED_REVISION_MAX_PER_TARGET_FREE=3
# PINNED_REVISION_MAX_PER_TARGET_PLUS=5
# PINNED_REVISION_MAX_PER_TARGET_SELFHOSTED=10

# =============================================================================
# File Storage
# =============================================================================
# "filesystem" (default) or "s3"
# For S3/MinIO: docker compose --profile s3 up
STORAGE_BACKEND=filesystem

# S3/MinIO settings (only used when STORAGE_BACKEND=s3)
S3_BUCKET=sheaf-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
# S3_PRESIGN_ENDPOINT=  # External URL for presigned redirects (if different from S3_ENDPOINT).
#   Needed when S3_ENDPOINT uses a Docker-internal hostname (e.g. http://minio:9000) that
#   the browser can't reach. Set to the externally-reachable URL (e.g. http://localhost:9000).
# S3_PUBLIC_URL=  # CDN URL prefix (e.g. Cloudflare-proxied domain); bypasses signed URL logic

# Upload limits
MAX_UPLOAD_SIZE_MB=5

# =============================================================================
# Image Serving
# =============================================================================
# "signed" (default): HMAC-signed URLs with expiry — prevents hotlinking.
#   Files served via /v1/files/{key}?token=...&expires=...
#   S3: serve endpoint redirects to a short-lived presigned S3 URL.
#   Filesystem: HMAC token validated on every request.
# "unsigned": no token required — anyone with a URL can access files.
#   WARNING: effectively provides free image hosting. Only use with S3_PUBLIC_URL
#   set to a Cloudflare-proxied domain with hotlink protection rules.
IMAGE_SERVING=signed

# Window size for signed URL expiry (seconds). All requests within the same
# window get the same URL, enabling browser/CDN image caching.
# Must be a clean divisor of a day (e.g. 1800, 3600, 7200). Default: 1 hour.
# FILE_URL_EXPIRY_SECONDS=3600

# =============================================================================
# Email
# =============================================================================
# "none" (default): no email sent. Password reset, email verification, and
#   account deletion confirmations are disabled.
# "smtp": send via SMTP server.
# "ses": send via AWS SES.
# "sendgrid": send via SendGrid API.
# EMAIL_BACKEND=none

# SMTP settings (only used when EMAIL_BACKEND=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=sheaf@example.com
# SMTP_TLS=true

# AWS SES settings (only used when EMAIL_BACKEND=ses)
# SES_REGION=us-east-1
# SES_FROM=sheaf@example.com
# SES_ACCESS_KEY=
# SES_SECRET_KEY=
# SQS queue URL for SES bounce/complaint events (via SNS → SQS).
# When set, Sheaf polls this queue and automatically handles bounces/complaints.
# SES_EVENTS_QUEUE_URL=

# SendGrid settings (only used when EMAIL_BACKEND=sendgrid)
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM=noreply@example.com
# Shared secret for the SendGrid Event Webhook. Configure SendGrid to POST to
# /v1/webhooks/sendgrid/events?token=<this value>. When empty, the webhook
# endpoint returns 404.
# SENDGRID_WEBHOOK_SECRET=

# =============================================================================
# Front-change notifications
# =============================================================================
# Sheaf can send a notification when fronts change to recipients the system
# owner has explicitly invited. v1 supports four destination types: web push,
# webhook (json/discord/slack/plaintext), ntfy, and Pushover.
#
# Each destination has its own setup. None are required for Sheaf to run; if
# the relevant config is missing, the destination type is unavailable to
# owners but the rest of Sheaf works.

# How often the dispatcher polls the outbox (seconds). Lower = snappier
# delivery, higher = less DB churn. Default 5s is fine for self-hosted.
# NOTIFICATIONS_DISPATCH_INTERVAL_SECONDS=5

# How long an unredeemed activation link is valid (days). After expiry the
# owner can re-issue a fresh link from the channel detail page.
# ACTIVATION_CODE_TTL_DAYS=7

# --- Web push (browser notifications) -----------------------------------------
# Generate a VAPID keypair once and keep it stable across deploys; rotating
# breaks every existing browser subscription. py-vapid is the easiest:
#   pip install py-vapid && vapid --gen
# That writes private_key.pem + applicationServerKey (base64url) to disk.
# VAPID_PUBLIC_KEY=BPaJk...   # the applicationServerKey base64url string
# VAPID_PRIVATE_KEY=/app/data/vapid_private.pem  # path or PEM-encoded literal
# Contact URI surfaced to push services, used by Mozilla/Google to reach
# you if a subscription misbehaves. Use a real mailto: or https:// URL.
# VAPID_SUBJECT=mailto:ops@example.com

# --- Pushover -----------------------------------------------------------------
# Register a Pushover application at https://pushover.net/apps and put the
# resulting app token here. The recipient's user_key is supplied per channel
# at create time. Empty = Pushover destination type is rejected with 501,
# UNLESS the channel supplies its own destination_config.app_token (BYO mode).
# PUSHOVER_APP_TOKEN=

# Monthly cap on shared-app Pushover deliveries. As of May 2026 Pushover
# gives each account a pooled 10000 messages/month free across all apps it
# owns, with paid upgrades at $50/10k, $115/25k, $200/50k, $300/100k,
# $1000/500k. Sheaf runs one app per instance, so one instance = one
# account's quota. Sheaf tracks deployment-wide usage in Redis and
# transient-fails shared-app deliveries once the cap is hit. Channels with
# destination_config.app_token (BYO) bypass this counter entirely. Set to
# 0 to disable Sheaf-side tracking and let Pushover-side enforcement be
# the only ceiling.
# PUSHOVER_MAX_PER_MONTH=10000

# Minimum debounce_seconds enforced on shared-app Pushover channels. Without
# this, one chatty system can burn the whole monthly cap for everyone on the
# instance — 30 minutes is a reasonable floor that still lets active users
# get reasonably timely pings without runaway. BYO channels are exempt.
# PUSHOVER_SHARED_APP_MIN_DEBOUNCE_SECONDS=1800

# Per-Sheaf-user monthly Pushover allowance on the shared app, by tier. Stops
# one user from monopolising the deployment quota. 0 = unlimited per-user
# (only the deployment-wide cap applies). BYO channels bypass this too.
# PUSHOVER_USER_MAX_PER_MONTH_FREE=100
# PUSHOVER_USER_MAX_PER_MONTH_PLUS=1000
# PUSHOVER_USER_MAX_PER_MONTH_SELF_HOSTED=0

# --- Discord webhook display --------------------------------------------------
# Owners can set destination_type=webhook + format=discord. These two settings
# control how the bot looks in Discord. Avatar must be a publicly reachable
# PNG/JPEG URL (Discord rejects SVG). Default avatar = the /sheaf-icon.png
# served by the frontend.
# DISCORD_WEBHOOK_USERNAME=Sheaf
# DISCORD_WEBHOOK_AVATAR_URL=

# --- Outbound webhook plumbing ------------------------------------------------
# Identifies Sheaf in webhook receiver logs. Bump the version if you fork or
# patch the dispatch logic so receivers can tell.
# WEBHOOK_USER_AGENT=Sheaf-Notifications/1.0

# Per-destination dispatch concurrency. Raise if you have many recipients on
# one destination type and your egress can take it; lower if a downstream is
# rate-limiting you.
# NOTIFICATIONS_CONCURRENCY_WEB_PUSH=10
# NOTIFICATIONS_CONCURRENCY_WEBHOOK=5
# NOTIFICATIONS_CONCURRENCY_NTFY=5
# NOTIFICATIONS_CONCURRENCY_PUSHOVER=5

# =============================================================================
# Registration
# =============================================================================
# "open" (default): anyone can register.
# "approval": account created but blocked until admin approves.
# "invite": registration requires a valid invite code.
# "closed": registration disabled.
REGISTRATION_MODE=open

# Accept invite codes even in open/approval mode (default: false).
# In "invite" mode, codes are always required regardless of this setting.
# In "approval" mode, a valid invite code bypasses the approval queue.
# INVITE_CODES_ENABLED=false

# "off" (default): no email verification required.
# "required": must verify email before account is usable.
# Requires EMAIL_BACKEND != none.
# EMAIL_VERIFICATION=off

# Minutes between password reset requests for the same account (default: 15).
# PASSWORD_RESET_RATE_LIMIT_MINUTES=15

# Base URL for the instance — used for email links (verification, password
# reset), as the JWT issuer claim, and to decide whether auth cookies should
# carry the Secure flag.
#
# Required when EMAIL_BACKEND is not "none". Optional otherwise, but strongly
# recommended: leave it unset and Sheaf assumes HTTPS and emits Secure cookies
# (correct for production behind a TLS reverse proxy). Set it to an http://
# URL to opt in to non-Secure cookies for plain-HTTP dev/LAN setups —
# browsers silently drop Secure cookies on HTTP origins, which breaks
# refresh-token rotation.
# SHEAF_BASE_URL=https://sheaf.example.com

# =============================================================================
# Admin
# =============================================================================
# Comma-separated list of emails to auto-promote to admin on startup.
# These users gain access to /admin in the UI and can create admin:* scoped API keys.
# SHEAF_ADMIN_EMAILS=you@example.com,colleague@example.com

# Step-up authentication required to access the admin dashboard.
# none (default) — any admin session has immediate access.
# password       — admin must re-enter their password each browser session.
# totp           — admin must enter a TOTP code; account must have TOTP enabled.
# Applies to session and JWT auth. API keys with admin:* scope are exempt.
# ADMIN_AUTH_LEVEL=none

# =============================================================================
# Testing
# =============================================================================
# Only needed when running pytest from the HOST machine while the DB runs inside
# Docker. The default DATABASE_URL uses Docker's internal 'db' hostname which
# isn't reachable from the host.
# Replace <POSTGRES_PASSWORD> with the value set above.
# SHEAF_TEST_DB_URL=postgresql+asyncpg://sheaf:<POSTGRES_PASSWORD>@localhost:5432/sheaf

# =============================================================================
# TLS for Mobile Dev (optional)
# =============================================================================
# Only needed for testing mobile apps locally — they require HTTPS.
# Usage: docker compose -f docker-compose.yml -f docker-compose.tls.yml up -d
#
# Point TLS_CERT_DIR at a directory containing cert.pem and key.pem.
# A wildcard Let's Encrypt cert via DNS-01 challenge works well:
#   certbot certonly --dns-cloudflare -d "*.dev.yourdomain.com"
#
# TLS_CERT_DIR=./certs
# TLS_HOSTNAME=sheaf-api.dev.yourdomain.com
# TLS_PORT=443

# =============================================================================
# Account Deletion
# =============================================================================
# Grace period before a deletion request is carried out (default: 7 days).
# Users can cancel during this window.
# ACCOUNT_DELETION_GRACE_DAYS=7

# Comma-separated list of days-before-deletion to send reminder emails.
# Only used when EMAIL_BACKEND != none.
# ACCOUNT_DELETION_REMINDER_DAYS=5,3,1

# =============================================================================
# Rate Limiting
# =============================================================================
# Global rate limit: max requests per IP per window, across all endpoints.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_GLOBAL_PER_IP=600
# RATE_LIMIT_GLOBAL_WINDOW=60

# Comma-separated IPs and/or CIDR ranges allowed to set X-Forwarded-For.
# Only these peers' forwarded headers are trusted for rate limiting. If
# empty, the direct connecting IP is always used.
# Bare IPs match exactly; CIDR ranges match any address inside them — useful
# when your reverse proxy runs in a docker-compose network whose bridge IP
# is dynamic.
# Examples:
#   TRUSTED_PROXIES=127.0.0.1
#   TRUSTED_PROXIES=127.0.0.1,::1
#   TRUSTED_PROXIES=127.0.0.1,172.16.0.0/12   # covers compose auto-assigned bridges
# TRUSTED_PROXIES=127.0.0.1

# =============================================================================
# Content Security
# =============================================================================
# Allow linking to external images (in bios and as avatar URLs). If false,
# such references are stripped on write and CSP blocks them at render time.
# Only images hosted on this instance are permitted.
# ALLOW_EXTERNAL_IMAGES=true

# Global toggle for image uploads. If false, only admins and users
# individually flipped to can_upload_images=True (via the admin users
# page) can upload. Useful for public test instances without a ToS.
# ALLOW_IMAGE_UPLOADS=true

# Narrower toggle for bio/description image embeds. Admin-only avatar/bio
# deploys can set this false while keeping ALLOW_IMAGE_UPLOADS=true for
# avatars. Admins and allowlisted users bypass either way.
# ALLOW_BIO_IMAGES=true

# Per-purpose upload size caps (MB). Both default to 0 which means "inherit
# MAX_UPLOAD_SIZE_MB". Set explicitly to give avatars a tight cap and bio
# illustrations a looser one (typical asymmetry).
# MAX_AVATAR_SIZE_MB=0
# MAX_BIO_IMAGE_SIZE_MB=0

# =============================================================================
# Public test / demo instance
# =============================================================================
# Requires the sheaf-devtools image (or a local build with INCLUDE_DEV_TOOLS=true).
# When enabled, deletes all non-admin users and their data every N hours.
# Rejected if SHEAF_MODE=saas. See docs/SELFHOSTING.md "Public test / demo
# instance mode" for details.
# DEMO_WIPE_ENABLED=false
# DEMO_WIPE_INTERVAL_HOURS=24

# =============================================================================
# Legal links
# =============================================================================
# URLs rendered as "Terms" / "Privacy" links in the footer. Leave empty to
# hide each link. Hide both to remove the footer entirely.
# TERMS_URL=https://sheaf.sh/terms
# PRIVACY_URL=https://sheaf.sh/privacy

# =============================================================================
# Captcha (optional — gates signup, and login if CAPTCHA_ON_LOGIN is on)
# =============================================================================
# Leave CAPTCHA_PROVIDER empty to disable. Only "altcha" is supported in v1
# (in-process proof-of-work, no third-party calls). Generate ALTCHA_HMAC_KEY
# with `openssl rand -hex 32` and keep it secret.
# CAPTCHA_PROVIDER=altcha
# ALTCHA_HMAC_KEY=
# ALTCHA_COMPLEXITY=50000
# CAPTCHA_ON_LOGIN=false

# =============================================================================
# General
# =============================================================================
# Set to 0 in production behind a reverse proxy
SHEAF_PORT=8000
SHEAF_HOST=0.0.0.0
