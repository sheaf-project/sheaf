# Sheaf Configuration
# Copy to .env and modify as needed: cp .env.example .env

# =============================================================================
# ENCRYPTION KEY — READ THIS
# =============================================================================
# If not set, Sheaf will auto-generate a key on first startup and save it to
# data/encryption.key. YOU MUST BACK THIS UP. If you lose it, all encrypted
# data (emails, TOTP secrets) is unrecoverable.
#
# To generate your own: python -c "import secrets; print(secrets.token_hex(32))"
# SHEAF_ENCRYPTION_KEY=your-fernet-key-here

# =============================================================================
# Database
# =============================================================================
POSTGRES_PASSWORD=changeme-in-production
DATABASE_URL=postgresql+asyncpg://sheaf:${POSTGRES_PASSWORD}@db:5432/sheaf

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Auth
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=changeme-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
SESSION_EXPIRE_HOURS=24

# =============================================================================
# Mode: "selfhosted" or "saas"
# =============================================================================
# Self-hosted: all features enabled, no tier restrictions, no pruning
# SaaS: tier-based feature gates, front history pruning for free tier
SHEAF_MODE=selfhosted

# =============================================================================
# SaaS Settings (only used when SHEAF_MODE=saas)
# =============================================================================
FREE_TIER_FRONT_RETENTION_DAYS=30

# =============================================================================
# File Storage
# =============================================================================
# "filesystem" (default) or "s3"
# For S3/MinIO: docker compose --profile s3 up
STORAGE_BACKEND=filesystem

# S3/MinIO settings (only used when STORAGE_BACKEND=s3)
S3_BUCKET=sheaf-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
# S3_PRESIGN_ENDPOINT=  # External URL for presigned redirects (if different from S3_ENDPOINT).
#   Needed when S3_ENDPOINT uses a Docker-internal hostname (e.g. http://minio:9000) that
#   the browser can't reach. Set to the externally-reachable URL (e.g. http://localhost:9000).
# S3_PUBLIC_URL=  # CDN URL prefix (e.g. Cloudflare-proxied domain); bypasses signed URL logic

# Upload limits
MAX_UPLOAD_SIZE_MB=5

# =============================================================================
# Image Serving
# =============================================================================
# "signed" (default): HMAC-signed URLs with expiry — prevents hotlinking.
#   Files served via /v1/files/{key}?token=...&expires=...
#   S3: serve endpoint redirects to a short-lived presigned S3 URL.
#   Filesystem: HMAC token validated on every request.
# "unsigned": no token required — anyone with a URL can access files.
#   WARNING: effectively provides free image hosting. Only use with S3_PUBLIC_URL
#   set to a Cloudflare-proxied domain with hotlink protection rules.
IMAGE_SERVING=signed

# Window size for signed URL expiry (seconds). All requests within the same
# window get the same URL, enabling browser/CDN image caching.
# Must be a clean divisor of a day (e.g. 1800, 3600, 7200). Default: 1 hour.
# FILE_URL_EXPIRY_SECONDS=3600

# =============================================================================
# Email
# =============================================================================
# "none" (default): no email sent. Password reset, email verification, and
#   account deletion confirmations are disabled.
# "smtp": send via SMTP server.
# "ses": send via AWS SES.
# "sendgrid": send via SendGrid API.
# EMAIL_BACKEND=none

# SMTP settings (only used when EMAIL_BACKEND=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=sheaf@example.com
# SMTP_TLS=true

# AWS SES settings (only used when EMAIL_BACKEND=ses)
# SES_REGION=us-east-1
# SES_FROM=sheaf@example.com
# SES_ACCESS_KEY=
# SES_SECRET_KEY=
# SQS queue URL for SES bounce/complaint events (via SNS → SQS).
# When set, Sheaf polls this queue and automatically handles bounces/complaints.
# SES_EVENTS_QUEUE_URL=

# SendGrid settings (only used when EMAIL_BACKEND=sendgrid)
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM=noreply@example.com
# Shared secret for the SendGrid Event Webhook. Configure SendGrid to POST to
# /v1/webhooks/sendgrid/events?token=<this value>. When empty, the webhook
# endpoint returns 404.
# SENDGRID_WEBHOOK_SECRET=

# =============================================================================
# Registration
# =============================================================================
# "open" (default): anyone can register.
# "approval": account created but blocked until admin approves.
# "invite": registration requires a valid invite code.
# "closed": registration disabled.
REGISTRATION_MODE=open

# Accept invite codes even in open/approval mode (default: false).
# In "invite" mode, codes are always required regardless of this setting.
# In "approval" mode, a valid invite code bypasses the approval queue.
# INVITE_CODES_ENABLED=false

# "off" (default): no email verification required.
# "required": must verify email before account is usable.
# Requires EMAIL_BACKEND != none.
# EMAIL_VERIFICATION=off

# Minutes between password reset requests for the same account (default: 15).
# PASSWORD_RESET_RATE_LIMIT_MINUTES=15

# Base URL for email links (verification, password reset).
# Required when EMAIL_BACKEND is not "none".
# SHEAF_BASE_URL=https://sheaf.example.com

# =============================================================================
# Admin
# =============================================================================
# Comma-separated list of emails to auto-promote to admin on startup.
# These users gain access to /admin in the UI and can create admin:* scoped API keys.
# SHEAF_ADMIN_EMAILS=you@example.com,colleague@example.com

# Step-up authentication required to access the admin dashboard.
# none (default) — any admin session has immediate access.
# password       — admin must re-enter their password each browser session.
# totp           — admin must enter a TOTP code; account must have TOTP enabled.
# Applies to session and JWT auth. API keys with admin:* scope are exempt.
# ADMIN_AUTH_LEVEL=none

# =============================================================================
# Testing
# =============================================================================
# Only needed when running pytest from the HOST machine while the DB runs inside
# Docker. The default DATABASE_URL uses Docker's internal 'db' hostname which
# isn't reachable from the host.
# Replace <POSTGRES_PASSWORD> with the value set above.
# SHEAF_TEST_DB_URL=postgresql+asyncpg://sheaf:<POSTGRES_PASSWORD>@localhost:5432/sheaf

# =============================================================================
# TLS for Mobile Dev (optional)
# =============================================================================
# Only needed for testing mobile apps locally — they require HTTPS.
# Usage: docker compose -f docker-compose.yml -f docker-compose.tls.yml up -d
#
# Point TLS_CERT_DIR at a directory containing cert.pem and key.pem.
# A wildcard Let's Encrypt cert via DNS-01 challenge works well:
#   certbot certonly --dns-cloudflare -d "*.dev.yourdomain.com"
#
# TLS_CERT_DIR=./certs
# TLS_HOSTNAME=sheaf-api.dev.yourdomain.com
# TLS_PORT=443

# =============================================================================
# Account Deletion
# =============================================================================
# Grace period before a deletion request is carried out (default: 7 days).
# Users can cancel during this window.
# ACCOUNT_DELETION_GRACE_DAYS=7

# Comma-separated list of days-before-deletion to send reminder emails.
# Only used when EMAIL_BACKEND != none.
# ACCOUNT_DELETION_REMINDER_DAYS=5,3,1

# =============================================================================
# Rate Limiting
# =============================================================================
# Global rate limit: max requests per IP per window, across all endpoints.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_GLOBAL_PER_IP=600
# RATE_LIMIT_GLOBAL_WINDOW=60

# Comma-separated IPs allowed to set X-Forwarded-For. Only these IPs'
# forwarded headers are trusted for rate limiting. If empty, the direct
# connecting IP is always used.
# Common values: 127.0.0.1 (localhost proxy), 172.17.0.1 (Docker bridge)
# TRUSTED_PROXIES=127.0.0.1

# =============================================================================
# Content Security
# =============================================================================
# Allow linking to external images (in bios and as avatar URLs). If false,
# such references are stripped on write and CSP blocks them at render time.
# Only images hosted on this instance are permitted.
# ALLOW_EXTERNAL_IMAGES=true

# Global toggle for image uploads. If false, only admins and users
# individually flipped to can_upload_images=True (via the admin users
# page) can upload. Useful for public test instances without a ToS.
# ALLOW_IMAGE_UPLOADS=true

# Narrower toggle for bio/description image embeds. Admin-only avatar/bio
# deploys can set this false while keeping ALLOW_IMAGE_UPLOADS=true for
# avatars. Admins and allowlisted users bypass either way.
# ALLOW_BIO_IMAGES=true

# Per-purpose upload size caps (MB). Both default to 0 which means "inherit
# MAX_UPLOAD_SIZE_MB". Set explicitly to give avatars a tight cap and bio
# illustrations a looser one (typical asymmetry).
# MAX_AVATAR_SIZE_MB=0
# MAX_BIO_IMAGE_SIZE_MB=0

# =============================================================================
# Public test / demo instance
# =============================================================================
# Requires the sheaf-devtools image (or a local build with INCLUDE_DEV_TOOLS=true).
# When enabled, deletes all non-admin users and their data every N hours.
# Rejected if SHEAF_MODE=saas. See docs/SELFHOSTING.md "Public test / demo
# instance mode" for details.
# DEMO_WIPE_ENABLED=false
# DEMO_WIPE_INTERVAL_HOURS=24

# =============================================================================
# Legal links
# =============================================================================
# URLs rendered as "Terms" / "Privacy" links in the footer. Leave empty to
# hide each link. Hide both to remove the footer entirely.
# TERMS_URL=https://sheaf.sh/terms
# PRIVACY_URL=https://sheaf.sh/privacy

# =============================================================================
# General
# =============================================================================
# Set to 0 in production behind a reverse proxy
SHEAF_PORT=8000
SHEAF_HOST=0.0.0.0
